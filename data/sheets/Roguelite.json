      "DESCRIPTION": "When Faith is removed, restores HP and gains that much Blessing."
    },
    "blessing": {
      "KEYWORD_NAME": "Blessing",
      "DESCRIPTION": "Increases Final DMG."
    },
    "resonance": {
      "KEYWORD_NAME": "Resonance",
      "DESCRIPTION": "After casting, casts all cards with Resonance in your discard pile."
    },
    "empowered": {
