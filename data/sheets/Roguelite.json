  "Keywords": {
    "multistrike": {
      "KEYWORD_NAME": "Multistrike",
      "DESCRIPTION": "Deals DMG multiple times."
    },
    "follow_up": {
      "KEYWORD_NAME": "Follow-up",
      "DESCRIPTION": "A special action that happens immediately after a condition is fulfilled."
    },
    "daze": {
      "KEYWORD_NAME": "Daze",
