      "KEYWORD_NAME": "Mana Crystal",
      "DESCRIPTION": "A 0 cost card. Adds 1 Energy next turn."
    },
    "storm": {
      "KEYWORD_NAME": "Storm",
      "DESCRIPTION": "Adds Lightning DMG as a Follow-up to all DMG you deal. (Scales: DEX)"
    },
    "fortitude": {
      "KEYWORD_NAME": "Fortitude",
      "DESCRIPTION": "Retains armor between turns. On turn start, loses 1 Fortitude."
    },
    "ephemeral": {
      "KEYWORD_NAME": "Ephemeral",
      "DESCRIPTION": "This card is removed from your deck until the end of combat after playing."
    },
    "armor": {
      "KEYWORD_NAME": "Armor",
      "DESCRIPTION": "Prevents DMG this turn."
    },
    "critical_hit": {
      "KEYWORD_NAME": "Critical Hit",
      "DESCRIPTION": "Critical hits deal double DMG."
    },
    "inspiration": {
      "KEYWORD_NAME": "Inspiration",
