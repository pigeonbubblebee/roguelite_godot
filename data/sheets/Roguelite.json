    },
    "insanity": {
      "KEYWORD_NAME": "Insanity",
      "DESCRIPTION": "The first time you gain Insanity each combat, adds Torment to your deck. When you lose HP, gain 1 Insanity."
    },
    "torment": {
      "KEYWORD_NAME": "Torment",
