      "DESCRIPTION": "Deal 50% more damage."
    },
    "vulnerable": {
      "KEYWORD_NAME": "Vulnerable",
      "DESCRIPTION": "Takes 50% more damage."
    },
    "rage": {
      "KEYWORD_NAME": "Rage",
